#!/bin/bash
# Resolve symlink to actual script location
SCRIPT_PATH="$(readlink -f "$0" 2>/dev/null || echo "$0")"
PROJECT_DIR="$(dirname "$SCRIPT_PATH")"
cd "$PROJECT_DIR"

case "$1" in
start)
  echo "🚀 启动 hermes-cn-webui..."
  npm run dev:all
  ;;
stop)
  echo "⏹  停止 hermes-cn-webui..."
  ./scripts/stop-all.sh
  ;;
restart)
  echo "🔄 重启 hermes-cn-webui..."
  ./scripts/stop-all.sh
  sleep 1
  npm run dev:all
  ;;
*)
  echo "用法: hermes-cnweb [start|stop|restart]"
  ;;
esac
